{
  "name": "monster",
  "label": "Foundit (Monster India)",
  "enabled": true,
  "strategy": "playwright_intercept",
  "bootstrap_url": null,
  "search_url": "https://www.foundit.in/srp/results?query={{keywords_url}}&locations={{locations_csv_url}}&postedDate={{job_age_days}}",
  "request": {},
  "response": {
    "items_path": "data.jobs",
    "intercept_url_contains": "jobsearch"
  },
  "paging": {
    "mode": "none"
  },
  "mappings": {
    "job_id": "jobId",
    "title": "title",
    "company": "company.name",
    "location": "locations[].city | join(', ', @)",
    "experience": "experienceMin",
    "experience_max": "experienceMax",
    "salary": "salaryMin",
    "posted_date": "postedDate",
    "description": "jobDescription",
    "apply_url": "jobId",
    "tech_stack": "skills[].name",
    "job_type": "jobType",
    "industry": "industryName"
  },
  "transforms": {
    "posted_date": "iso_to_ymd",
    "apply_url": "monster_jobid_to_url",
    "experience": "monster_exp_range",
    "tech_stack": "list_clean"
  }
}
